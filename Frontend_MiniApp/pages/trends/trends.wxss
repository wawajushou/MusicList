/* 榜单速递样式 */

/* 来源标识 */
.source-badge {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.02) 0%, rgba(0, 0, 0, 0.04) 100%);
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.source-content {
  display: flex;
  align-items: center;
}

.source-logo-box {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1ec978 0%, #17a85e 100%);
  border-radius: 14rpx;
  margin-right: 16rpx;
}

.logo-icon {
  font-size: 28rpx;
}

.source-info {
  display: flex;
  flex-direction: column;
}

.source-text {
  font-size: 20rpx;
  color: var(--text-light);
  letter-spacing: 2rpx;
}

.source-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 4rpx;
}

.update-hint {
  margin-left: auto;
  padding: 8rpx 16rpx;
  background-color: rgba(30, 201, 120, 0.1);
  border-radius: 20rpx;
}

.update-hint-text {
  font-size: 20rpx;
  color: #1ec978;
  font-weight: 500;
}

/* 加载状态 */
.loading-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 榜单卡片 */
.chart-card {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.chart-title {
  display: flex;
  align-items: center;
}

.chart-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
}

.chart-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.chart-meta {
  display: flex;
  align-items: center;
}

.chart-count {
  font-size: 22rpx;
  color: var(--text-light);
  background-color: rgba(0, 0, 0, 0.04);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
}

/* 歌曲列表 */
.song-list {
  display: flex;
  flex-direction: column;
}

.song-item {
  display: flex;
  align-items: center;
  padding: 18rpx 12rpx;
  border-bottom: 1rpx solid var(--border);
  border-radius: 12rpx;
  transition: background-color 0.2s;
}

.song-item:active {
  background-color: rgba(0, 0, 0, 0.03);
}

.song-item:last-child {
  border-bottom: none;
}

.song-rank {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  border-radius: 12rpx;
  background-color: rgba(0, 0, 0, 0.04);
}

.rank-top {
  background: linear-gradient(135deg, var(--accent) 0%, #e85a3a 100%);
}

.rank-top .rank-num {
  color: #fff !important;
}

.rank-num {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.song-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.song-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.song-artist {
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 展开按钮 */
.expand-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 0 6rpx;
  margin-top: 12rpx;
  border-top: 1rpx dashed var(--border);
}

.expand-text {
  font-size: 24rpx;
  color: var(--accent);
  margin-right: 8rpx;
  font-weight: 500;
}

.expand-arrow {
  font-size: 18rpx;
  color: var(--accent);
}

/* 空状态 */
.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: var(--text-light);
}
