/* 我的曲库样式 */

.page-header {
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 入口卡片 */
.entry-card {
  cursor: pointer;
  transition: all 0.2s ease;
}

.entry-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.card-content {
  display: flex;
  align-items: center;
}

.card-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-primary);
  border-radius: 16rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.card-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.card-arrow {
  font-size: 36rpx;
  color: var(--text-light);
  font-weight: 300;
}
