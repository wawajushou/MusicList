/* 今日看板样式 */

/* 天气卡片 */
.weather-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.9) 0%, rgba(248, 248, 250, 0.8) 100%);
  position: relative;
  overflow: hidden;
}

.weather-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -30%;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(168, 168, 170, 0.15) 0%, transparent 70%);
  border-radius: 50%;
}

/* 位置名称 */
.weather-location {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid var(--border);
}

.location-main {
  display: flex;
  align-items: center;
}

.location-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.location-district {
  font-size: 22rpx;
  color: var(--text-light);
  background-color: rgba(0, 0, 0, 0.04);
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
}

.weather-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.weather-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.weather-info {
  flex: 1;
}

.weather-date {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 加载动画 */
.weather-loading {
  display: flex;
  gap: 6rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background-color: var(--accent);
  border-radius: 50%;
  animation: loadingBounce 1.4s infinite ease-in-out;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes loadingBounce {
  0%, 80%, 100% {
    transform: scale(0);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.weather-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--border);
  flex-wrap: wrap;
  gap: 12rpx;
}

.weather-temp {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.weather-range {
  font-size: 22rpx;
  color: var(--text-light);
  background-color: rgba(0, 0, 0, 0.03);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.weather-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.weather-advice {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.advice-item {
  display: flex;
  align-items: center;
}

.advice-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
  width: 36rpx;
  text-align: center;
}

.advice-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 降雨警告样式 */
.rain-warning {
  background-color: rgba(255, 59, 48, 0.08);
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  margin: 4rpx 0;
}

.rain-warning .advice-text {
  color: #ff3b30;
  font-weight: 500;
}

/* 歌单标题区 */
.playlist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 32rpx 0 24rpx;
  padding: 0 8rpx;
}

.playlist-title {
  display: flex;
  align-items: center;
}

.playlist-title .emoji {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.playlist-update {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: rgba(0, 0, 0, 0.03);
  padding: 10rpx 18rpx;
  border-radius: 20rpx;
}

.update-label {
  font-size: 20rpx;
  color: var(--text-light);
}

.update-time {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--accent);
}

/* 歌曲列表 */
.song-list {
  display: flex;
  flex-direction: column;
}

.song-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.song-item:last-child {
  border-bottom: none;
}

.song-index {
  width: 48rpx;
  font-size: 24rpx;
  color: var(--text-light);
  text-align: center;
}

.song-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

/* 新歌推荐 */
.new-song-list {
  display: flex;
  flex-direction: column;
}

.new-song-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.new-song-item:last-child {
  border-bottom: none;
}

.new-song-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.new-song-source {
  font-size: 22rpx;
  color: var(--text-light);
  padding: 6rpx 16rpx;
  background-color: var(--bg-primary);
  border-radius: 12rpx;
}

/* 首页特有样式 */
.section-card {
  position: relative;
}

.section-card::after {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4rpx;
  height: 32rpx;
  background-color: var(--accent);
  border-radius: 2rpx;
  opacity: 0.5;
}
