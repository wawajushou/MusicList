/* 历史歌单记录样式 */

.page-header {
  margin-bottom: 32rpx;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* 加载和空状态 */
.loading-box,
.empty-box {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text,
.empty-text {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 歌单列表 */
.playlist-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 歌单卡片 */
.playlist-card {
  background-color: var(--bg-card);
  border-radius: 16rpx;
  overflow: hidden;
}

.playlist-header {
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  position: relative;
}

.playlist-date {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.playlist-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-item {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.summary-divider {
  font-size: 20rpx;
  color: var(--border);
}

.expand-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: var(--text-light);
}

/* 歌单详情 */
.playlist-detail {
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid var(--border);
}

.stage-section {
  margin-top: 20rpx;
}

.stage-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
  margin-bottom: 12rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid var(--accent);
}

.stage-songs {
  display: flex;
  flex-direction: column;
}

.detail-song {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
  background-color: rgba(0, 0, 0, 0.02);
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.detail-index {
  width: 40rpx;
  font-size: 22rpx;
  color: var(--text-light);
  text-align: center;
}

.detail-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.detail-source {
  font-size: 22rpx;
  color: var(--accent);
  background-color: rgba(0, 0, 0, 0.04);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.new-song {
  background-color: rgba(0, 0, 0, 0.04);
}
